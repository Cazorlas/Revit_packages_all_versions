<Project>
  <PropertyGroup>
    <RevitVersion Condition="'$(RevitVersion)' == ''">2024</RevitVersion>
    <_RevitPackageVersionDir>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\revit\$(RevitVersion)'))</_RevitPackageVersionDir>
    <DefineConstants>$(DefineConstants);REVIT$(RevitVersion)</DefineConstants>
  </PropertyGroup>

  <Target Name="_ValidateRevitPackageVersion" BeforeTargets="ResolveReferences">
    <Error
      Condition="!Exists('$(_RevitPackageVersionDir)\RevitAPI.dll')"
      Text="RevitPackagesAllVersions does not contain a populated DLL folder for RevitVersion='$(RevitVersion)'. Expected RevitAPI.dll under '$(_RevitPackageVersionDir)'." />
  </Target>

  <Target
    Name="_AddRevitPackageReferences"
    BeforeTargets="ResolveReferences"
    DependsOnTargets="_ValidateRevitPackageVersion">
    <ItemGroup>
      <_RevitPackageDll Include="$(_RevitPackageVersionDir)\*.dll" />

      <Reference Include="%(_RevitPackageDll.Filename)">
        <HintPath>%(_RevitPackageDll.Identity)</HintPath>
        <Private>false</Private>
        <SpecificVersion>false</SpecificVersion>
      </Reference>
    </ItemGroup>
  </Target>
</Project>
